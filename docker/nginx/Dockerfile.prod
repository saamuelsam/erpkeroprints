FROM node:24-alpine AS frontend

WORKDIR /var/www

COPY package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install --ignore-scripts; fi

COPY resources ./resources
COPY vite.config.js ./
COPY public ./public
RUN npm run build

FROM nginx:1.25-alpine

WORKDIR /var/www

COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY public ./public
COPY --from=frontend /var/www/public/build ./public/build
RUN ln -s /var/www/storage/app/public /var/www/public/storage
